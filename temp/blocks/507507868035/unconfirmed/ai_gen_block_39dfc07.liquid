    <div class="product-info__block-item" data-block-id="liquid_VYgyhr" data-block-type="liquid"><div class="product-info__liquid">
                  <div class="product-info__block-item" data-block-id="liquid_ayckTY" data-block-type="liquid">
      <div class="product-info__liquid">
        <div class="main-product__block main-product__block-custom_liquid">
          <div class="m-product-text">
            <div class="main-product__block main-product__block-custom_liquid">
              <div class="m-product-text">
                <div class="main-product__block main-product__block-custom_liquid">
                  <div class="m-product-text">
                    <div class="product-info__liquid">
                      <a class="image-size" style="display: flex; align-items: center; gap: 8px;">
                        <img src="https://cdn.shopify.com/s/files/1/0776/3751/7627/files/avis.png?v=1687213619" alt="Étoiles" width="63" height="13">
                        <span class="text-size">Noté <b>4,8/5</b> sur la base de 400 avis</span>
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
                </div></div>
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-review-rating-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-review-rating__link-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.gap }}px;
    text-decoration: none;
    color: {{ block.settings.text_color }};
  }

  .ai-review-rating__stars-{{ ai_gen_id }} {
    flex-shrink: 0;
  }

  .ai-review-rating__stars-{{ ai_gen_id }} img {
    display: block;
    width: {{ block.settings.stars_width }}px;
    height: auto;
  }

  .ai-review-rating__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.4;
  }

  .ai-review-rating__text-{{ ai_gen_id }} b {
    font-weight: 600;
  }

  @media screen and (max-width: 749px) {
    .ai-review-rating__link-{{ ai_gen_id }} {
      gap: {{ block.settings.gap | times: 0.8 }}px;
    }

    .ai-review-rating__stars-{{ ai_gen_id }} img {
      width: {{ block.settings.stars_width | times: 0.8 }}px;
    }

    .ai-review-rating__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-review-rating-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <a 
    href="{{ block.settings.link_url }}" 
    class="ai-review-rating__link-{{ ai_gen_id }}"
    {% if block.settings.link_url == blank %}aria-disabled="true" style="pointer-events: none;"{% endif %}
  >
    {% if block.settings.stars_image %}
      <span class="ai-review-rating__stars-{{ ai_gen_id }}">
        <img 
          src="{{ block.settings.stars_image | image_url: width: 200 }}" 
          alt="{{ block.settings.stars_alt_text }}"
          width="{{ block.settings.stars_width }}"
          height="auto"
          loading="lazy"
        >
      </span>
    {% endif %}
    
    {% if block.settings.rating_text != blank %}
      <span class="ai-review-rating__text-{{ ai_gen_id }}">
        {{ block.settings.rating_text }}
      </span>
    {% endif %}
  </a>
</div>

{% schema %}
{
  "name": "Review rating",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "image_picker",
      "id": "stars_image",
      "label": "Stars image"
    },
    {
      "type": "text",
      "id": "stars_alt_text",
      "label": "Stars image alt text",
      "default": "Étoiles"
    },
    {
      "type": "inline_richtext",
      "id": "rating_text",
      "label": "Rating text",
      "default": "Noté <b>4,8/5</b> sur la base de 400 avis"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "stars_width",
      "label": "Stars width",
      "min": 40,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 65
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Space between stars and text",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#003c40"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Review rating"
    }
  ]
}
{% endschema %}
